       mkdir -p /tmp/temp_trt ; mkdir -p /root/tmp ; mkdir -p /tmp99 && \
       cd /tmp/temp_trt && \
       apt-add-repository ppa:mosquitto-dev/mosquitto-ppa && \
       cp /tmp/docker/rsyslog /etc/init.d/ && \
       ls -l /tmp/temp_trt/ && \
       chmod +x /etc/init.d/rsyslog && \
       dpkg -i /tmp/docker/nv-tensorrt-local-repo-ubuntu2404-10.14.1-cuda-13.0_1.0-1_amd64.deb && \
       dpkg -i /tmp/docker/cudnn-local-repo-ubuntu2404-9.17.1_1.0-1_amd64.deb && \
       ls -l /tmp/temp_trt/ && \
       cp /tmp/docker/libgstrtpmanager.so /tmp99/libgstrtpmanager.so && \
