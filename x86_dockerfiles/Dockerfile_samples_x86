# open telemetry 
 RUN --mount=type=bind,src=x86_dockerfiles,target=/tmp/docker \
     mkdir -p /tmp/temp_otel99 && \
     cd /tmp/temp_otel99 && \
     cp  /tmp/docker/optel/* . && \
     dpkg -i *.deb && \
     cd / && \
     rm -rf /tmp/temp_otel99


RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install --reinstall -y --allow-downgrades libprotobuf32t64=3.21.12-8.2ubuntu0.3 libprotoc32t64=3.21.12-8.2ubuntu0.3 && \
    apt-get install -y --no-install-recommends protobuf-compiler libprotobuf-dev=3.21.12-8.2ubuntu0.3 && \
    mkdir -p /opt/proto/bin && \
    ln -sf /usr/bin/protoc /opt/proto/bin/protoc && \
    rm -rf /var/lib/apt/lists/*


# workaround deepstream-app --version-all for cudnn
RUN ln -s /usr/lib/x86_64-linux-gnu/libcudnn.so.9 /usr/lib/x86_64-linux-gnu/libcudnn.so

# workaround for deepstream --version-all cuda driver
RUN ln -s  /usr/local/cuda/lib64/libcudart.so.13  /usr/local/cuda/lib64/libcudart.so

# ENV NVIDIA_DRIVER_CAPABILITIES $NVIDIA_DRIVER_CAPABILITIES,video
ENV NVIDIA_DRIVER_CAPABILITIES $NVIDIA_DRIVER_CAPABILITIES,video,compute,graphics,utility

WORKDIR /opt/nvidia/deepstream/deepstream


ENV PATH="${PATH}:${HOME}/.local/bin"
ENV LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:${HOME}/.local/lib"
ENV PKG_CONFIG_PATH="${PKG_CONFIG_PATH}:${HOME}/.local/lib/pkgconfig"

ENV LD_PRELOAD /usr/lib/x86_64-linux-gnu/libgomp.so.1:/usr/lib/x86_64-linux-gnu/libGLdispatch.so:$LD_PRELOAD

RUN ldconfig

