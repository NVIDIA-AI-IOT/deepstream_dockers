        ls -l /tmp/docker ; mkdir -p /tmp99 ; mkdir -p /root/tmp ; apt-add-repository ppa:mosquitto-dev/mosquitto-ppa ;  apt-get update && \
        DEBIAN_FRONTEND=noninteractive  apt-get install -y --no-install-recommends \
