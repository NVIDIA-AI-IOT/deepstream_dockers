FROM nvcr.io/nvidia/tritonserver:26.01-py3


ENV DS_VERSION=9.0

# Removing unnecessary nvidia entries in sources.list
RUN head -n -2 /etc/apt/sources.list > /tmp/tmp.txt && mv /tmp/tmp.txt /etc/apt/sources.list


