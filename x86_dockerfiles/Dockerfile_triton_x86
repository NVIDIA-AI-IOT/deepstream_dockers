        rsyslog \
        libjsoncpp-dev \
        vim  rsync \
        gstreamer1.0-rtsp \
        libcairo2 \
        libpangocairo-1.0-0 \
        libx11-6 \
        libyaml-cpp-dev \
        libc-dev-bin\
        libc6 \
        libcurl3-gnutls \
        libc-bin \
        libpmi2-0 \
        libcurl4 \
        apparmor-utils \
        mosquitto \
        libmosquitto-dev \
        libhiredis-dev \
        librdkafka1 \
        libcups2t64 \
        libdpkg-perl \
        libcjson-dev \
        dpkg-dev \
        dpkg \
        curl && \
        tar --version ; tar -xvf /tmp/docker/deepstream_sdk_v9.0.0_x86_64.tbz2 -C / ;  /opt/nvidia/deepstream/deepstream/install.sh && \
        /tmp/docker/gRPC_installation.sh && \
        cp /tmp/docker/libgstrtpmanager.so /tmp99/libgstrtpmanager.so && \
        cp /tmp/docker/libgstrtsp.so /tmp99/libgstrtsp.so && \
        cp /tmp/docker/libgstvideoparsersbad.so /tmp99/libgstvideoparsersbad.so && \
        cp /tmp/docker/rsyslog /etc/init.d/ && \
        chmod +x /etc/init.d/rsyslog && \
        mkdir -p /usr/share/glvnd/egl_vendor.d/ && \
        cp /tmp/docker/10_nvidia.json /usr/share/glvnd/egl_vendor.d/10_nvidia.json && \
        cp /tmp/docker/entrypoint.sh /opt/nvidia/deepstream/deepstream/ && \
        rm -rf /var/lib/apt/lists/* && \
        rm -rf /root/tmp && \
        apt autoremove && \
        cp /tmp/docker/LicenseAgreementContainer.pdf /opt/nvidia/deepstream/deepstream/ && \
        cp  /tmp/docker/user_additional_install_devel.sh /opt/nvidia/deepstream/deepstream/user_additional_install.sh && \
        cp  /tmp/docker/user_deepstream_python_apps_install.sh /opt/nvidia/deepstream/deepstream/user_deepstream_python_apps_install.sh && \
        cp /tmp/docker/entrypoint.sh /opt/nvidia/deepstream/deepstream/ && \
        rm -rf /var/lib/apt/lists/* && \
        rm -rf /root/tmp && \
        apt autoremove


# Fix CVE for h11 - CVE-2025-43859
RUN pip3 install httpcore==1.0.9

# Fix CVE-2025-47273 (setuptools) and CVE-2026-24049 
RUN pip3 install setuptools==78.1.1 jaraco.context==6.1.0 

# Fix CVE-2025-62727 (Starlette) 
RUN pip3 install starlette==0.52.1 fastapi

# open telemetry 
 RUN --mount=type=bind,src=x86_dockerfiles,target=/tmp/docker \
     mkdir -p /tmp/temp_otel99 && \
     cd /tmp/temp_otel99 && \
     cp  /tmp/docker/optel/* . && \
     dpkg -i *.deb && \
     cd / && \
     rm -rf /tmp/temp_otel99



RUN mkdir -p /opt/tritonclient/ && \
        mkdir -p /tmp/temp_triton99 && \
        mkdir -p /opt/proto && \
        mkdir -p /tmp/temp_proto99 && \
        mkdir -p /opt/half && \
        mkdir -p /tmp/half99 && \
        cd /tmp/temp_triton99 && \
        wget https://github.com/triton-inference-server/server/releases/download/v2.65.0/v2.65.0_ubuntu2404.clients.tar.gz -nv && \
        tar xzf v2.65.0_ubuntu2404.clients.tar.gz -C /opt/tritonclient/ lib include && \
        cd /tmp/temp_proto99 && \
        cd /tmp/half99 && \
        wget https://sourceforge.net/projects/half/files/half/2.1.0/half-2.1.0.zip -nv && \
        /usr/bin/unzip /tmp/half99/half-2.1.0.zip -d /opt/half && \
        cd / && \
        rm -rf /tmp/temp_triton99 && \
        rm -rf /tmp/temp_proto99 && \
        rm -rf /tmp/half99



RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install --reinstall -y --allow-downgrades libprotobuf32t64=3.21.12-8.2ubuntu0.3 libprotoc32t64=3.21.12-8.2ubuntu0.3 && \
    apt-get install -y --no-install-recommends protobuf-compiler libprotobuf-dev=3.21.12-8.2ubuntu0.3 && \
    mkdir -p /opt/proto/bin && \
    ln -sf /usr/bin/protoc /opt/proto/bin/protoc && \
    rm -rf /var/lib/apt/lists/*

# ENV NVIDIA_DRIVER_CAPABILITIES $NVIDIA_DRIVER_CAPABILITIES,video,graphics
ENV NVIDIA_DRIVER_CAPABILITIES $NVIDIA_DRIVER_CAPABILITIES,video,compute,graphics,utility

ENV LD_LIBRARY_PATH /opt/tritonserver/lib:/usr/src/tensorrt/lib:/opt/riva/lib:/usr/local/cuda-12/lib64:/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH


ENTRYPOINT ["/opt/nvidia/deepstream/deepstream-9.0/entrypoint.sh"]

WORKDIR  /opt/nvidia/deepstream/deepstream-9.0/

RUN ln -s /usr/lib/x86_64-linux-gnu/libnvidia-encode.so.1 /usr/lib/x86_64-linux-gnu/libnvidia-encode.so && \
 ln -s /usr/lib/x86_64-linux-gnu/libnvidia-ml.so.1 /usr/lib/x86_64-linux-gnu/libnvidia-ml.so && \
 ln -s /usr/src/tensorrt/bin/trtexec /usr/bin/trtexec


ENV PATH="/opt/proto/bin:${PATH}:${HOME}/.local/bin"
ENV LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:${HOME}/.local/lib"
ENV PKG_CONFIG_PATH="${PKG_CONFIG_PATH}:${HOME}/.local/lib/pkgconfig"

RUN ldconfig

# IP requirement for removal
RUN rm -f /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstaudioparsers.so \
        /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstx264.so \
        /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstfaad.so \
        /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstvoaacenc.so 
RUN rm -f /usr/lib/x86_64-linux-gnu/libavresample* /usr/lib/x86_64-linux-gnu/libavutil* \
        /usr/lib/x86_64-linux-gnu/libavcodec* /usr/lib/x86_64-linux-gnu/libavformat* \
        /usr/lib/x86_64-linux-gnu/libavfilter*  /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstde265.so* \
        /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstx265.so* /usr/lib/x86_64-linux-gnu/libde265.so* /usr/lib/x86_64-linux-gnu/gstreamer-1.0/libgstvpx.so*
RUN rm -f /usr/lib/x86_64-linux-gnu/libmpeg2.so* /usr/lib/x86_64-linux-gnu/libmpeg2encpp-2.1.so* /usr/lib/x86_64-linux-gnu/libmpg123.so*  \
